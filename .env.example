RESOLUTION_CHECK_MAX_MARKETS=200
RESOLUTION_CHECK_PROGRESS_EVERY_MARKETS=25
RESOLUTION_CHECK_FETCH_CONCURRENCY=2
RESOLUTION_CHECK_WORKER_RATE_LIMIT_MS=250
RESOLUTION_BACKFILL_MAX_RUNS=3
RESOLUTION_BACKFILL_MAX_DURATION_MS=900000
RESOLUTION_BACKFILL_MAX_MARKETS=400
RESOLUTION_BACKFILL_FETCH_CONCURRENCY=3
RESOLUTION_BACKFILL_WORKER_RATE_LIMIT_MS=200

GAP_DETECTION_MAX_MARKETS=500
GAP_DETECTION_PROGRESS_EVERY_MARKETS=25

SNAPSHOT_CANDIDATE_LIMIT=1000
SNAPSHOT_ACTIVE_WINDOW_HOURS=24
SNAPSHOT_MIN_VOLUME_24H=1000
SNAPSHOT_MIN_LIQUIDITY=1000
MARKET_PRUNE_MIN_AGE_HOURS=24
MARKET_PRUNE_BATCH_SIZE=1000
